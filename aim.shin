local u72 = false
local _LocalPlayer = game.Players.LocalPlayer
local _CurrentCamera = game.Workspace.CurrentCamera

local function u86()
    local _huge = math.huge
    local v76, v77, v78 = pairs(game.Players:GetPlayers())
    local v79 = nil

    while true do
        local v80

        v78, v80 = v76(v77, v78)

        if v78 == nil then
            break
        end
        if v80 ~= _LocalPlayer and v80.Character and v80.Character:FindFirstChild('Head') then
            local v81, v82 = _CurrentCamera:WorldToScreenPoint(v80.Character.Head.Position)
            local _Magnitude = (Vector2.new(v81.X, v81.Y) - Vector2.new(_CurrentCamera.ViewportSize.X / 2, _CurrentCamera.ViewportSize.Y / 2)).Magnitude

            if v82 and _Magnitude < _huge and _Magnitude <= _Frame.Size.X.Offset / 2 then
                local v84 = Ray.new(_CurrentCamera.CFrame.Position, (v80.Character.Head.Position - _CurrentCamera.CFrame.Position).unit * 3000)
                local v85 = game.Workspace:FindPartOnRay(v84, _LocalPlayer.Character, false, true)

                if v85 then
                    if v85:IsDescendantOf(v80.Character) then
                        v79 = v80
                        _huge = _Magnitude
                    end
                end
            end
        end
    end

    return v79
end
local function v89()
    if u72 then
        local v87 = u86()

        if v87 and v87.Character then
            local v88 = nil

            if u68[1].Head ~= true or not v87.Character:FindFirstChild('Head') then
                if u68[1].Chest ~= true or not v87.Character:FindFirstChild('HumanoidRootPart') then
                    if u68[1].Pelvis and v87.Character:FindFirstChild('LowerTorso') then
                        v88 = v87.Character.LowerTorso
                    end
                else
                    v88 = v87.Character.HumanoidRootPart
                end
            else
                v88 = v87.Character.Head
            end
            if v88 then
                _CurrentCamera.CFrame = CFrame.new(_CurrentCamera.CFrame.Position, v88.Position)
            end
        end
    end
end

