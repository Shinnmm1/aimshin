local function u98(p91)
    local _dsdsd, v93, v94 = p91:match('(%d+),%s*(%d+),%s*(%d+)')
    local v95 = tonumber(_dsdsd)
    local v96 = tonumber(v93)
    local v97 = tonumber(v94)

    if v95 and (v96 and v97) and (0 <= v95 and v95 <= 255 and (0 <= v96 and v96 <= 255)) and (0 <= v97 and v97 <= 255) then
        return true, Color3.fromRGB(v95, v96, v97)
    else
        return false, Color3.fromRGB(0, 0, 0)
    end
end

